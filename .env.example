# Database
DATABASE_URL=postgresql://cms:changeme_secure_password@db:5432/opnsense_cms

# FastAPI
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
DEBUG=false

# SMTP Configuration
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=cms@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=cms@example.com
SMTP_USE_TLS=true

# OPNsense API Settings
VERIFY_SSL=false
POLLING_INTERVAL_SECONDS=300
REQUEST_TIMEOUT_SECONDS=30

# Backup Settings
BACKUP_RETENTION_COUNT=30
BACKUP_DIRECTORY=./backups

# Scheduler Settings
LICENSE_CHECK_HOUR=2
MONITORING_INTERVAL_SECONDS=10
MONITORING_INTERVAL_MINUTES=5
SMART_CHECK_HOUR=3
UPDATE_CHECK_INTERVAL_MINUTES=30

# Timezone for logging and scheduling (default: "UTC")
# Examples: "Europe/Berlin", "America/New_York", "Asia/Tokyo"
TIMEZONE=UTC

# Backup scheduling is configured per firewall in the GUI

# AI Configuration (for Config History Analysis)
# Optional: Leave blank to disable AI analysis features
# VITE_AI_PROVIDER: 'openai' | 'anthropic' | 'ollama' | 'custom'
VITE_AI_PROVIDER=openai
VITE_AI_MODEL=gpt-4-turbo
VITE_AI_API_KEY=sk-...

# For custom OpenAI-compatible endpoint (vLLM, LiteLLM, etc.):
# VITE_AI_API_ENDPOINT=http://localhost:8000/v1
# VITE_AI_MODEL=your-model-name
# VITE_AI_API_KEY=any-value (some servers don't require it)

# For Ollama (local): uncomment and set
# VITE_AI_PROVIDER=ollama
# VITE_AI_MODEL=mistral
# VITE_AI_API_ENDPOINT=http://localhost:11434/api/generate

# For Anthropic Claude: uncomment and set
# VITE_AI_PROVIDER=anthropic
# VITE_AI_MODEL=claude-3-opus-20240229
# VITE_AI_API_KEY=sk-ant-...
